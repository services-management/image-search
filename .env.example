# =============================================================================
# ML Image Search Service - Environment Variables
# =============================================================================

# --- Service ---
# Service name (used in logs and health checks)
SERVICE_NAME=ml-search-service
# Port the ML service listens on
SERVICE_PORT=8001

# --- API Connections ---
# URL of the main catalog/database API (used for hybrid search)
MAIN_API_URL=http://api:8000

# --- ML Model Paths ---
# YOLO: Hugging Face hosted model (auto-downloaded and cached on first run)
# Format: hf://USERNAME/REPO/filename.pt
YOLO_MODEL=hf://albkue/car-parts-yolov8/best.pt

# CLIP: huggingface model name
# Must match EMBEDDING_DIMENSION in config.py (768 for clip-vit-large-patch14)
CLIP_MODEL=openai/clip-vit-large-patch14

# --- Detection Thresholds ---
# YOLO minimum confidence (0.0-1.0). Higher = fewer false positives.
YOLO_CONFIDENCE_THRESHOLD=0.5

# OCR minimum confidence (0.0-1.0). Lower = reads more text but may include noise.
# For product labels, 0.3 is recommended. For clean documents, 0.6+.
OCR_CONFIDENCE_THRESHOLD=0.3

# --- Storage ---
# Directory for FAISS vector index files
FAISS_INDEX_PATH=/app/data/faiss_index

# --- Hardware ---
# Set to 'true' to use NVIDIA GPU with CUDA
USE_GPU=false

# --- CORS ---
# Allowed frontend origins. Use '*' for all (dev only).
# Production: comma-separated list, e.g. https://app.example.com,https://admin.example.com
CORS_ORIGINS=*
